{
  "name": "@asicupv/engage-paella-player",
  "version": "8.0.3",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/polimediaupv/paella-opencast"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "files": [
    "dist/*",
    "ui/*",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build:ghpages": "USE_OC_SERVER_FROM_URL=true OC_PAELLA8_BASE_URL='/paella-opencast' OC_PRESENTATION_URL='https://develop.opencast.org' CONFIG_FOLDER='https://polimediaupv.github.io/paella-opencast/config/' OC_PAELLA8_URL_TEMPLATE='/paella-opencast/watch.html?id={videoId}&ocServer={OC_PRESENTATION_URL}' vite build",
    "build": "tsc && vite build && vite build -c vite.config.embedapi.ts --emptyOutDir false",
    "preview": "vite preview",
    "test:e2e": "node ../../node_modules/@playwright/test/cli.js test -c ../../playwright.config.ts",
    "test:e2e:headed": "node ../../node_modules/@playwright/test/cli.js test -c ../../playwright.config.ts --headed",
    "clean:build": "rimraf .turbo dist",
    "clean:deps": "rimraf node_modules"
  },
  "devDependencies": {
    "@asicupv/paella-opencast-component": "2.0.4",
    "@asicupv/paella-opencast-core": "2.0.4",
    "@asicupv/paella-opencast-plugins": "2.0.4",
    "@asicupv/paella-opencast-skin": "2.0.1",
    "@asicupv/paella-ai-plugins": "^2.8.2",
    "@asicupv/paella-basic-plugins": "^2.6.1",
    "@asicupv/paella-embedapi": "^2.12.0",
    "@asicupv/paella-extra-plugins": "^2.9.1",
    "@asicupv/paella-slide-plugins": "^2.6.1",
    "@asicupv/paella-video-plugins": "^2.5.2",
    "@asicupv/paella-webgl-plugins": "^2.4.1",
    "@asicupv/paella-zoom-plugin": "^2.5.3",
    "@tailwindcss/vite": "^4.3.0",
    "express": "^5.2.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-static-copy": "^4.1.0"
  }
}
